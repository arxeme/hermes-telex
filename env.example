# hermes-telex environment (single-account quickstart).
# Full config incl. multi-account lives in ~/.hermes/config.yaml under
# platforms.telex.extra — see docs/spec/td_hermes-telex-plugin_zh.md §5.

# Required: Telex bot API key (X-API-Key). Shown once at register/rotate.
TELEX_API_KEY=

# Optional: Voyager API host (default https://voyager.ingarena.net).
# TELEX_BASE_URL=https://voyager.ingarena.net

# Optional: the bot's own identity id (16-char hex). Hardens self-echo
# suppression from the first frame (also learned from the first send response).
# TELEX_BOT_ID=

# Direct-message policy: open | allowlist | pairing (default allowlist).
# "open" requires TELEX_ALLOW_FROM to include "*".
# TELEX_DM_POLICY=allowlist
# TELEX_ALLOW_FROM=alice@example.com,0a1b2c3d4e5f6071

# Channel policy: disabled | allowlist | open (default disabled).
# TELEX_GROUP_POLICY=disabled
# TELEX_GROUP_ALLOW_FROM=<channel conversation id>,<...>
# TELEX_GROUP_SENDER_ALLOW_FROM=alice@example.com
# TELEX_GROUP_REQUIRE_MENTION=true

# Show a "processing" activity indicator while the agent works: activity | off.
# TELEX_PROCESSING_INDICATOR=activity

# Cron / send_message default delivery target (conversation id or peer/<id>).
# TELEX_HOME_CHANNEL=
# TELEX_HOME_CHANNEL_NAME=Telex Home
