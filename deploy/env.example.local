# Connection target for deploy-telex-plugin.sh / cleanup-telex-plugin.sh.
# Copy to deploy/env.local and fill in (env.local is gitignored via *.local).
# These select WHERE to deploy (SMC + Incus VM); runtime secrets go in deploy/.env.

# SMC profile used by `smc -c <profile> toc/scp` to reach the test server.
SMC_PROFILE=

# Voyager test server, reachable via `smc toc <host>`.
# Find the host in voyager/docs/operations/test-server.md (the LAN IP it uses
# with `smc toc`). Do not commit the real host here — fill it only in env.local.
SERVER_HOST=

# Incus VM on the test server that runs the hermes-agent instance.
VM_NAME=
REMOTE_USER=

# Paths inside the VM (defaults shown; override only if your install differs).
REMOTE_HERMES_HOME=/home/openclaw/.hermes
REMOTE_HERMES_INSTALL_DIR=/home/openclaw/hermes-agent
# REMOTE_PLUGIN_DIR defaults to <REMOTE_HERMES_HOME>/plugins/telex-platform
